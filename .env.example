# Postgres (Docker on Windows host)
POSTGRES_PASSWORD=changeme

# pgAdmin web UI (http://localhost:5050)
PGADMIN_EMAIL=admin@outlastsolutions.com
PGADMIN_PASSWORD=changeme

# Connection string — set Windows host LAN IP
DATABASE_URL=postgresql://osaio:changeme@192.168.x.x:5432/osaio

# ── LLM providers ─────────────────────────────────────────────────────────
# Set one or both. Provider is inferred from model ID prefix.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Model selection per agent role ─────────────────────────────────────────
# Claude examples:  claude-sonnet-4-6  claude-opus-4-6  claude-haiku-4-5-20251001
# Gemini examples:  gemini-2.5-flash   gemini-2.5-pro
PM_MODEL=gemini-2.5-flash
APM_MODEL=gemini-2.5-flash
PLANNER_MODEL=gemini-2.5-flash
BUILDER_MODEL=gemini-2.5-pro
AUDITOR_MODEL=gemini-2.5-flash

# ── Slack ──────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_TASKS_CHANNEL=C0AJL6RCYKU
