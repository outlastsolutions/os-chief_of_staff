# Postgres (Docker on Windows host)
POSTGRES_PASSWORD=changeme

# pgAdmin web UI (http://localhost:5050)
PGADMIN_EMAIL=admin@outlastsolutions.com
PGADMIN_PASSWORD=changeme

# Connection string used by chief_of_staff (point to Windows host IP from the VM)
# Find your Windows host IP: run `ipconfig` on Windows, look for your LAN IP
# Or use host.docker.internal if running from inside Docker
DATABASE_URL=postgresql://osaio:changeme@192.168.x.x:5432/osaio

GEMINI_API_KEY=
